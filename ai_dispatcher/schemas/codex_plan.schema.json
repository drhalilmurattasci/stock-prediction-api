{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ai_dispatcher Codex Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["dispatch_id", "goal", "related_files", "notes"],
  "properties": {
    "dispatch_id": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "related_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
